# WANXIANG 部署环境变量示例
# 复制为 .env 再修改

# 服务监听
WANXIANG_HOST=0.0.0.0
WANXIANG_PORT=8000
WANXIANG_LOG_LEVEL=info
WANXIANG_WORKERS=1

# 默认 LLM 提供方密钥（可选；不填则只能用 stub provider）
# 申请：https://platform.deepseek.com/
WANXIANG_DEEPSEEK_API_KEY=

# 多租户表（M3-3 鉴权）。不填则只内置一个 demo 租户：
#   api_key=demo-key, tenant_id=demo, rpm_limit=60
# 生产环境务必填入真实租户，避免 demo-key 被滥用：
# WANXIANG_TENANTS_JSON=[{"tenant_id":"acme","api_key":"sk-acme-2026","rpm_limit":120}]
WANXIANG_TENANTS_JSON=
