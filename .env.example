# ============================================================
# WANXIANG 部署环境配置
# ============================================================
# 用法: cp .env.example .env && 修改下面的值再 docker compose up -d
# ============================================================

# --- Compose profile 选择 (默认 full 完整栈) ---
# full    : api + postgres + redis + celery-worker (推荐生产)
# minimal : 仅 api-minimal (SQLite + 进程内 asyncio, MVP 单机)
#   切到 minimal: docker compose --profile minimal up -d  (无需改 .env)
COMPOSE_PROFILES=full

# --- API 服务 ---
WANXIANG_PORT=8000
WANXIANG_HOST=0.0.0.0
WANXIANG_LOG_LEVEL=info
WANXIANG_WORKERS=1   # uvicorn workers

# --- 模型 (DeepSeek 或私有 LLM) ---
# 申请: https://platform.deepseek.com/
WANXIANG_DEEPSEEK_API_KEY=sk-...your-deepseek-api-key...
# 自有 LLM 网关: 在 SimulateRequest 里直接传 base_url/api_key 覆盖

# --- 多租户 ---
# JSON 数组; 空则使用默认 demo 租户 (api_key=demo-key, tenant_id=demo, rpm=60)
# 生产务必填入真实租户, 避免 demo-key 被滥用:
# WANXIANG_TENANTS_JSON=[{"tenant_id":"acme","api_key":"sk-acme-2026","rpm_limit":120,"default_locale":"zh"}]
WANXIANG_TENANTS_JSON=

# --- PostgreSQL (完整栈) ---
# !! 生产环境务必修改密码 !!
POSTGRES_USER=wanxiang
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=wanxiang
# 上层 API 默认通过下面这个 DSN 连接 (docker 内网域名 postgres)
# 如果上面改了 USER/PASS, 这里也要同步改:
# WANXIANG_TASKS_DB=postgresql://wanxiang:changeme-strong-password@postgres:5432/wanxiang

# --- 任务队列 ---
# WANXIANG_TASK_QUEUE=asyncio   # MVP 单机, 走进程内 asyncio (minimal profile 默认)
# WANXIANG_TASK_QUEUE=celery    # 生产, Celery worker 异步执行 (full profile 默认)
CELERY_CONCURRENCY=4             # celery worker 并发数

# --- Redis (EventBus + Celery broker/backend) ---
# WANXIANG_EVENT_BUS=memory  # 单机, 进程内 asyncio.Queue (minimal profile 默认)
# WANXIANG_EVENT_BUS=redis   # 多 worker, Redis Pub/Sub + LIST 历史 (full profile 默认)

# --- 国际化 ---
# 客户端通过请求体 locale 或 Accept-Language 头切换 zh/en
# 租户级默认在 WANXIANG_TENANTS_JSON 里 default_locale 字段
